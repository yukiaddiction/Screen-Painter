<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Screen_Painter.ViewModels"
             x:Class="Screen_Painter.Views.ImageEditorPage"
             x:DataType="vm:ImageEditorViewModel"
             Title="Image Framing &amp; Ratio Editor"
             BackgroundColor="{AppThemeBinding Light={StaticResource LightPageBg}, Dark={StaticResource DarkPageBg}}">

    <Grid RowDefinitions="*, Auto" Padding="{StaticResource PageMargin}">
        <!-- Live Framing Canvas Visualizer (mirrors device screen framing) -->
        <Border Grid.Row="0" Style="{StaticResource PreviewCanvasBorder}" Margin="{StaticResource EditorCanvasMargin}">
            <Grid>
                <!-- Ghost layer: full picture, dimmed, unclipped — shows what extends beyond the screen -->
                <Image Source="{Binding PreviewImageSource}" Aspect="Fill" Opacity="0.35"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       WidthRequest="{Binding GhostWidth}" HeightRequest="{Binding GhostHeight}"
                       TranslationX="{Binding PreviewOffsetX}" TranslationY="{Binding PreviewOffsetY}"
                       IsVisible="{Binding HasGhost}" InputTransparent="True" />

                <!-- Screen-shaped clipped frame: full bitmap at true extent + proportional offsets, exactly like the applied wallpaper -->
                <Grid HorizontalOptions="Center" VerticalOptions="Center"
                      WidthRequest="{Binding PreviewFrameWidth}" HeightRequest="{Binding PreviewFrameHeight}"
                      IsClippedToBounds="True" BackgroundColor="Black">
                    <Image Source="{Binding PreviewImageSource}" Aspect="Fill"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           WidthRequest="{Binding GhostWidth}" HeightRequest="{Binding GhostHeight}"
                           TranslationX="{Binding PreviewOffsetX}" TranslationY="{Binding PreviewOffsetY}"
                           IsVisible="{Binding HasGhost}" />
                    <Image Source="{Binding PreviewImageSource}" Aspect="AspectFill"
                           Scale="{Binding Scale}" TranslationX="{Binding PreviewOffsetX}" TranslationY="{Binding PreviewOffsetY}"
                           IsVisible="{Binding ShowFallbackFramedImage}" />
                    <Label Text="&#x1F5BC; No preview available" 
                           HorizontalOptions="Center" VerticalOptions="Center" 
                           TextColor="White" Opacity="0.6" IsVisible="{Binding ShowPlaceholder}" />
                </Grid>

                <!-- Accent outline marking the applied screen area -->
                <Border HorizontalOptions="Center" VerticalOptions="Center"
                        WidthRequest="{Binding PreviewFrameWidth}" HeightRequest="{Binding PreviewFrameHeight}"
                        Stroke="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource DarkAccent}}"
                        StrokeThickness="2" Background="Transparent" InputTransparent="True" />

                <Label Text="Non-Destructive framing preview (Original file unmodified)" 
                       Style="{StaticResource SmallCaptionLabel}" HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,12" />

                <!-- Touch control overlay: drag to move, pinch to zoom -->
                <Grid BackgroundColor="Transparent">
                    <Grid.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnPreviewPanUpdated" />
                        <PinchGestureRecognizer PinchUpdated="OnPreviewPinchUpdated" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Grid>
        </Border>

        <!-- Adjustment Controls -->
        <Border Grid.Row="1" Style="{StaticResource PreviewCanvasBorder}" Padding="{StaticResource CardPadding}">
            <VerticalStackLayout Spacing="{StaticResource GroupSpacing}">
                <Label Text="Framing Parameters" Style="{StaticResource SectionSubtitleLabel}" FontAttributes="Bold" 
                       TextColor="{AppThemeBinding Light={StaticResource LightPrimaryText}, Dark={StaticResource DarkPrimaryText}}" />

                <!-- Scale Slider -->
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Label Grid.Column="0" Text="Scale" 
                           TextColor="{AppThemeBinding Light={StaticResource LightPrimaryText}, Dark={StaticResource DarkPrimaryText}}" VerticalOptions="Center" WidthRequest="60" />
                    <Slider Grid.Column="1" Maximum="3.0" Minimum="{Binding ScaleMinimum}" Value="{Binding Scale}" 
                            MinimumTrackColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource DarkAccent}}" 
                            MaximumTrackColor="{AppThemeBinding Light={StaticResource LightPageBg}, Dark={StaticResource DarkPageBg}}" 
                            ThumbColor="{AppThemeBinding Light={StaticResource LightSecondaryText}, Dark={StaticResource DarkPrimaryText}}" />
                    <Label Grid.Column="2" Text="{Binding Scale, StringFormat='{0:F2}x'}" 
                           Style="{StaticResource SmallCaptionLabel}" WidthRequest="50" HorizontalTextAlignment="End" VerticalOptions="Center" />
                </Grid>

                <!-- Offset X Slider -->
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Label Grid.Column="0" Text="Offset X" 
                           TextColor="{AppThemeBinding Light={StaticResource LightPrimaryText}, Dark={StaticResource DarkPrimaryText}}" VerticalOptions="Center" WidthRequest="60" />
                    <Slider Grid.Column="1" Maximum="{Binding OffsetXMaximum}" Minimum="{Binding OffsetXMinimum}" Value="{Binding OffsetX}" 
                            MinimumTrackColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource DarkAccent}}" 
                            MaximumTrackColor="{AppThemeBinding Light={StaticResource LightPageBg}, Dark={StaticResource DarkPageBg}}" 
                            ThumbColor="{AppThemeBinding Light={StaticResource LightSecondaryText}, Dark={StaticResource DarkPrimaryText}}" />
                    <Label Grid.Column="2" Text="{Binding OffsetX, StringFormat='{0:F0}px'}" 
                           Style="{StaticResource SmallCaptionLabel}" WidthRequest="50" HorizontalTextAlignment="End" VerticalOptions="Center" />
                </Grid>

                <!-- Offset Y Slider -->
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Label Grid.Column="0" Text="Offset Y" 
                           TextColor="{AppThemeBinding Light={StaticResource LightPrimaryText}, Dark={StaticResource DarkPrimaryText}}" VerticalOptions="Center" WidthRequest="60" />
                    <Slider Grid.Column="1" Maximum="{Binding OffsetYMaximum}" Minimum="{Binding OffsetYMinimum}" Value="{Binding OffsetY}" 
                            MinimumTrackColor="{AppThemeBinding Light={StaticResource LightAccent}, Dark={StaticResource DarkAccent}}" 
                            MaximumTrackColor="{AppThemeBinding Light={StaticResource LightPageBg}, Dark={StaticResource DarkPageBg}}" 
                            ThumbColor="{AppThemeBinding Light={StaticResource LightSecondaryText}, Dark={StaticResource DarkPrimaryText}}" />
                    <Label Grid.Column="2" Text="{Binding OffsetY, StringFormat='{0:F0}px'}" 
                           Style="{StaticResource SmallCaptionLabel}" WidthRequest="50" HorizontalTextAlignment="End" VerticalOptions="Center" />
                </Grid>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="{StaticResource ItemSpacing}" Margin="{StaticResource SectionBottomMargin}">
                    <Button Grid.Column="0" Text="Reset" Command="{Binding ResetFramingCommand}" 
                            Style="{StaticResource SecondaryButton}" HeightRequest="{StaticResource StandardButtonHeight}" CornerRadius="{StaticResource ButtonCornerRadius}" />
                    <Button Grid.Column="1" Text="Apply Framing" Command="{Binding SaveFramingCommand}" 
                            Style="{StaticResource ActionButton}" CornerRadius="{StaticResource ButtonCornerRadius}" HeightRequest="{StaticResource StandardButtonHeight}" />
                </Grid>

                <Button Text="Remove Per-Image Override (Use Collection Default)" Command="{Binding RemoveOverrideCommand}" 
                        IsVisible="{Binding IsPerImageMode}" Style="{StaticResource DangerButton}" 
                        HeightRequest="{StaticResource StandardButtonHeight}" CornerRadius="{StaticResource ButtonCornerRadius}" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
