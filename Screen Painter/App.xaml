<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Screen_Painter"
             xmlns:converters="clr-namespace:Screen_Painter.Converters"
             x:Class="Screen_Painter.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/Layouts.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:PreviewImageAtIndexConverter x:Key="PreviewImageAtIndex" />
            <converters:PreviewCellVisibleConverter x:Key="PreviewCellVisible" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
